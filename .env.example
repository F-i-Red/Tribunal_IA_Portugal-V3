# Tribunal IA Portugal — Configuração
# Obtém chave gratuita em: https://openrouter.ai/keys

OPENROUTER_API_KEY=COLA AQUI A TUA API KEY

# Modelo (opcional) — algumas opções:
# Modelo (opcional) — algumas opções:
# MODELO="anthropic/claude-haiku-4-5"                    # pago, rápido
# MODELO="google/gemini-2.0-flash-001"                   # pago, muito barato
# MODELO="openrouter/free"                               # ⭐ gratuito, router automático
# MODELO="meta-llama/llama-3.3-70b-instruct:free"        # gratuito, bom equilíbrio
# MODELO="deepseek/deepseek-r1:free"                     # gratuito, raciocínio
MODELO="openrouter/free"

# Configurações gerais
MAX_RETRIES=3
REQUEST_TIMEOUT=120
LOG_LEVEL=INFO
GUARDAR_ATAS=true
ANONIMIZAR_ENTIDADES=true
CACHE_ENABLED=true
PARALELISMO=true
MODO_ECONOMICO=false