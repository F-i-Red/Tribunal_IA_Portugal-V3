# =============================================================
# TRIBUNAL IA PORTUGAL — Configuração de Ambiente
# =============================================================

# --- OpenRouter (chave GRATUITA em https://openrouter.ai/) ---
OPENROUTER_API_KEY=sk-or-v1- tua-chave-aqui

# --- Modelo a usar ---
# Recomendado: llama-3.3-70b (grátis, estável, segue bem instruções em PT)
# Se falhar, o sistema tenta automaticamente outros modelos gratuitos.
#
# Modelos gratuitos estáveis (Abril 2026):
#   meta-llama/llama-3.3-70b-instruct:free   ← RECOMENDADO
#   google/gemma-3-27b-it:free
#   mistralai/mistral-7b-instruct:free
#
# Modelos pagos (melhor qualidade):
#   anthropic/claude-sonnet-4-5
#   google/gemini-2.5-pro
MODELO=meta-llama/llama-3.3-70b-instruct:free

# --- Configurações ---
GUARDAR_ATAS=true
PASTA_ATAS=output_atas/
PASTA_LEIS=data/leis/
